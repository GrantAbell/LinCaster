{
  "version": 1,
  "device": {
    "usb_vendor_id": 6647,
    "usb_product_ids": [121, 120],
    "alsa_card_id_hint": "RODECaster",
    "require_multitrack": true
  },
  "busses": [
    { "bus_id": "system", "display_name": "System",    "direction": "playback", "channels": 2, "default_gain": 1.0 },
    { "bus_id": "chat",   "display_name": "Chat",      "direction": "playback", "channels": 2, "default_gain": 1.0 },
    { "bus_id": "game",   "display_name": "Game",      "direction": "playback", "channels": 2, "default_gain": 1.0 },
    { "bus_id": "music",  "display_name": "Music",     "direction": "playback", "channels": 2, "default_gain": 0.8 },
    { "bus_id": "a",      "display_name": "Virtual A", "direction": "playback", "channels": 2, "default_gain": 1.0 },
    { "bus_id": "b",      "display_name": "Virtual B", "direction": "playback", "channels": 2, "default_gain": 1.0 }
  ],
  "routes": [
    { "from_bus_id": "system", "to_target": "hardware:multitrack_playback",  "channel_map": { "left": 0, "right": 1 } },
    { "from_bus_id": "game",   "to_target": "hardware:multitrack_playback",  "channel_map": { "left": 2, "right": 3 } },
    { "from_bus_id": "music",  "to_target": "hardware:multitrack_playback",  "channel_map": { "left": 4, "right": 5 } },
    { "from_bus_id": "a",      "to_target": "hardware:multitrack_playback",  "channel_map": { "left": 6, "right": 7 } },
    { "from_bus_id": "b",      "to_target": "hardware:multitrack_playback",  "channel_map": { "left": 8, "right": 9 } },
    { "from_bus_id": "chat",   "to_target": "hardware:chat_playback_stereo" }
  ],
  "app_rules": [
    {
      "match": { "process_name_regex": "^(discord|Discord)$" },
      "target_bus_id": "chat",
      "priority": 100,
      "enabled": true
    },
    {
      "match": { "app_name_regex": "^WEBRTC VoiceEngine$" },
      "target_bus_id": "chat",
      "priority": 100,
      "enabled": true
    },
    {
      "match": { "process_name_regex": "^(zoom|zoom\\.real)$" },
      "target_bus_id": "chat",
      "priority": 100,
      "enabled": true
    },
    {
      "match": { "process_name_regex": "^(teams|ms-teams)$" },
      "target_bus_id": "chat",
      "priority": 100,
      "enabled": true
    },
    {
      "match": { "process_name_regex": "^(steam|gamescope)$" },
      "target_bus_id": "game",
      "priority": 90,
      "enabled": true
    },
    {
      "match": { "process_name_regex": "^(spotify|Spotify)$" },
      "target_bus_id": "music",
      "priority": 80,
      "enabled": true
    },
    {
      "match": { "app_name_regex": "^(Rhythmbox|Clementine|Lollypop)$" },
      "target_bus_id": "music",
      "priority": 75,
      "enabled": true
    }
  ],
  "latency_mode": "low"
}
